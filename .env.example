# ─── Server-side secrets (Netlify Functions / netlify dev) ─────────────────
# These are NOT prefixed with VITE_ — they are never bundled into client JS.
# Set them in Netlify → Site Settings → Environment Variables for production.
# For local development, set them here (.env is read automatically by netlify dev).

# Shared passphrase shown to staff before the form loads (read only by verify-passphrase)
PASSPHRASE=your-passphrase-here

# Secret used to HMAC-sign session tokens issued by verify-passphrase.
# Generate a strong random value: npm run gen-secret
AUTH_SECRET=your-long-random-secret-here

# Upstash Redis (REST) — backs per-IP rate limiting on verify-passphrase & chat.
# Create a free database at console.upstash.com; rate limiting is skipped if unset.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Asana Personal Access Token (Settings → Apps → Personal access tokens)
ASANA_PAT=your-pat-here

# GID of the "OGC Deacons" Asana project
# Find it in the project URL: app.asana.com/0/<PROJECT_GID>/...
ASANA_PROJECT_GID=your-project-gid-here

# GID of the "Inbox" section inside that project
# Fetch via: GET https://app.asana.com/api/1.0/projects/<PROJECT_GID>/sections
ASANA_INBOX_SECTION_GID=your-section-gid-here

ANTHROPIC_API_KEY=your-key-here

# Notion internal integration token (read-only, scoped to roster DB)
# Create at: notion.so/my-integrations
NOTION_TOKEN=your-notion-integration-token-here

# GID of the Notion database containing the deacon roster
# Get it from the database URL: notion.so/<WORKSPACE>/<DATABASE_ID>?v=...
NOTION_ROSTER_DB_ID=your-notion-database-id-here
